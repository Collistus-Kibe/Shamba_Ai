# ═══════════════════════════════════════════════════════════════════════════════
# SHAMBA AI — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App Settings ─────────────────────────────────────────────────────────────
PROJECT_NAME=Shamba AI
API_V1_STR=/api/v1

# ─── Database Configuration ──────────────────────────────────────────────────
# Supported: sqlite, postgresql, mysql+pymysql (TiDB Cloud)
# SQLite (local development default):
DATABASE_URL=sqlite:///./shamba_ai.db
# PostgreSQL example:
# DATABASE_URL=postgresql://username:password@host:5432/shamba_ai_db
# TiDB Cloud example:
# DATABASE_URL=mysql+pymysql://username:password@gateway.tidbcloud.com:4000/shamba_ai_db?ssl_ca=/path/to/ca.pem

# ─── JWT Authentication ──────────────────────────────────────────────────────
# IMPORTANT: Replace with a strong, random secret key in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── AI Services — Gemini (Google) ────────────────────────────────────────────
# Primary Gemini API key (used for chat assistant and vision-based disease diagnosis)
GEMINI_API_KEY_1=your_gemini_api_key_1_here
# Secondary/fallback Gemini API key (for rate-limit failover)
GEMINI_API_KEY_2=your_gemini_api_key_2_here

# ─── AI Services — OpenAI ────────────────────────────────────────────────────
# Primary OpenAI API key (used for advanced NLP tasks and voice transcription)
OPENAI_API_KEY_1=your_openai_api_key_1_here
# Secondary/fallback OpenAI API key (for rate-limit failover)
OPENAI_API_KEY_2=your_openai_api_key_2_here

# ─── Plant Disease Detection — Plant.id ──────────────────────────────────────
# API key for Plant.id crop disease identification service
# Get your key at: https://plant.id/
PLANT_ID_API_KEY=your_plant_id_api_key_here

# ─── Weather Services ────────────────────────────────────────────────────────
# OpenWeatherMap API key for real-time weather data
# Get your key at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# ─── Firebase Configuration ──────────────────────────────────────────────────
# [PENDING] Firebase integration is architecturally prepared but paused.
# Provide credentials when ready to activate Firebase Auth & Storage.
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_CREDENTIALS_JSON=/path/to/firebase-service-account.json
# Alternative: paste inline JSON string instead of file path
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ─── Satellite Data Provider ─────────────────────────────────────────────────
# Choose active satellite provider: 'sentinel' (default) or 'gee'
SATELLITE_PROVIDER=sentinel

# ─── Sentinel Hub (ACTIVE satellite provider) ────────────────────────────────
# Get credentials at: https://www.sentinel-hub.com/
# Create an OAuth client under Dashboard → User Settings → OAuth Clients
SENTINEL_API_KEY=your_sentinel_hub_client_secret
SENTINEL_USER_ID=your_sentinel_hub_client_id

# ─── Google Earth Engine (INACTIVE — Keep for Future Use) ────────────────────
# Set SATELLITE_PROVIDER=gee to activate once credentials are configured.
EARTH_ENGINE_CREDENTIALS_PATH=/path/to/gee-private-key.json
EARTH_ENGINE_PROJECT_ID=your_gcp_project_id
GEE_SERVICE_ACCOUNT_EMAIL=your_gee_service_account@project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_FILE=/path/to/gee-private-key.json

# ─── CORS / Frontend URL ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-production-domain.com

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
